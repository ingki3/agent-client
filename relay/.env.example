# Copy to `.env` (gitignored) and fill in. Loaded automatically by the npm scripts.
#
# Telegram MTProto app credentials from https://my.telegram.org/apps
# (required for the user-account path: phone login + send/receive as the user)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# 32-byte-derived master key that encrypts bot tokens AND MTProto session strings at rest.
# Use a long random string. If unset, a fixed DEV key is used (loud warning) — fine for
# local testing, but set a real one before storing a real session you care about.
RELAY_MASTER_KEY=

# Optional overrides
# PORT=8787
# HOST=0.0.0.0
# RELAY_DB=relay.db

# OpenAI-compatible model endpoint for helper AI + TTS script rewriting.
# Default provider is Gemini via Google's OpenAI-compatible endpoint.
# API key is still sent as a Bearer token because OpenAI-compatible clients expect it.
GEMINI_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-3.5-flash
LLM_MAX_TOKENS=32000
LLM_HELPER_MAX_TOKENS=1024
LLM_TTS_MAX_TOKENS=2048
LLM_CONCURRENCY=4
