# Copy to `.env` (gitignored) and fill in. Loaded automatically by the npm scripts.
#
# Telegram MTProto app credentials from https://my.telegram.org/apps
# (required for the user-account path: phone login + send/receive as the user)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# 32-byte-derived master key that encrypts bot tokens AND MTProto session strings at rest.
# Use a long random string. If unset, a fixed DEV key is used (loud warning) — fine for
# local testing, but set a real one before storing a real session you care about.
RELAY_MASTER_KEY=

# Optional overrides
# PORT=8787
# HOST=0.0.0.0
# RELAY_DB=relay.db
